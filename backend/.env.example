PORT=5000
MONGODB_URI=mongodb://localhost:27017/plantorium
API_BASE_URL=http://localhost:5000

# Admin API key (optional - when set, PUT/upload require X-Admin-Key header)
# ADMIN_API_KEY=your_secret_admin_key

# Cloudinary (required for image/video uploads)
# Get credentials from https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
